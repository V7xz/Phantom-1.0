    local secTgt=pageAimbot:Section({Name="Target",Side=2})
    secTgt:Dropdown({Name="Target Part",Default="Head",     Items={"Head","HumanoidRootPart"},Callback=function(v) S.aimPart=v end})
    secTgt:Dropdown({Name="Priority",   Default="Crosshair",Items={"Crosshair","Distance"},   Callback=function(v) S.aimPriority=v end})
    secTgt:Slider({Name="Max Distance",Min=0,Max=2000,Default=500,Suffix=" st",              Callback=function(v) S.aimMaxDist=v end})

    local secFOV=pageAimbot:Section({Name="FOV Circle",Side=1})
    secFOV:Slider({Name="FOV Radius",Min=20,Max=800,Default=250,Suffix=" px",Callback=function(v) S.aimFOV=v end})
    local fovColLbl=secFOV:Label("Circle Color")
    fovColLbl:Colorpicker({Name="Color",Default=Color3.fromRGB(0,196,255),Callback=function(v) S.aimFovCol=v end})

    local secSmooth=pageAimbot:Section({Name="Smoothing",Side=2})
    secSmooth:Slider({Name="Smoothness",   Min=0,Max=20,Default=5,    Suffix="",  Callback=function(v) S.aimSmooth=v   end})
    secSmooth:Toggle({Name="Prediction",   Default=false,Flag="AimbotPrediction", Callback=function(v) S.aimPred=v    end})
    secSmooth:Slider({Name="Pred Strength",Min=0,Max=1,  Default=0.165,Decimals=3,Suffix="",Callback=function(v) S.aimPredStr=v end})

    -- ============================================================
    -- VISUALS — ESP + Whitelist
    -- ============================================================
    Window:Category("Visuals")
    local pageESP = Window:Page({Name="ESP",       Icon="100050851789190"})
    local pageWL  = Window:Page({Name="Whitelist", Icon="123554105934637"})

    local secESP=pageESP:Section({Name="Player ESP",Side=1})
    secESP:Toggle({Name="Enable ESP",                 Default=false,Flag="ESPEnabled",  Callback=function(v) S.ESP_ENABLED=v  end})
    secESP:Toggle({Name="Skeleton ESP (CPU comsume)", Default=false,Flag="SkeletonESP", Callback=function(v) S.ESP_SKELETON=v end})
    secESP:Slider({Name="Max Distance",Min=50,Max=2000,Default=500,Suffix=" st",        Callback=function(v) S.ESP_MAX_DIST=v end})

    local secESPOpt  = pageESP:Section({Name="Options",Side=2})
    local boxColorLbl = secESPOpt:Label("Box Color")
    boxColorLbl:Colorpicker({Name="BoxColor",Default=Color3.fromRGB(0,255,255),
        Callback=function(v) S.ESP_BOX_COLOR=v; if S.updateESPColor then S.updateESPColor(v) end end})
    secESPOpt:Label("Shows: Box, Name, HP,")
    secESPOpt:Label("Distance, Tool, Skeleton")

    -- Whitelist — also uses improved PlayerAdded detection
    local secWL=pageWL:Section({Name="Whitelist",Side=1})
    secWL:Label("Ignored by ESP & Aimbot")
    local function getWLText()
        local n={}; for nm in pairs(S.whitelist) do table.insert(n,nm) end
        return #n==0 and "None" or table.concat(n,", ")
    end
    local wlLbl=secWL:Label("Whitelisted: None")
    local wlPN={}; local selWL=nil
    local function updateWL()
        wlPN={}
        for _,p in pairs(Players:GetPlayers()) do
            if p~=LocalPlayer and not S.whitelist[p.Name] then table.insert(wlPN,p.Name) end
        end
    end
    updateWL()
    local wlDD=secWL:Dropdown({Name="Player",Items=wlPN,Default=wlPN[1] or "-",Callback=function(v) selWL=v end})
    secWL:Button({Name="Refresh List",Callback=function()
        updateWL(); pcall(function() wlDD.Items=wlPN end)
        if #wlPN>0 then selWL=wlPN[1] else selWL=nil end
    end})
    secWL:Button({Name="Add",     Callback=function() if not selWL or selWL=="-" then return end; S.whitelist[selWL]=true;  updateWL(); wlLbl:Set("WL: "..getWLText()) end})
    secWL:Button({Name="Remove",  Callback=function() if not selWL or selWL=="-" then return end; S.whitelist[selWL]=nil;   updateWL(); wlLbl:Set("WL: "..getWLText()) end})
    secWL:Button({Name="Clear All",Callback=function() S.whitelist={}; updateWL(); wlLbl:Set("WL: None") end})
    Players.PlayerAdded:Connect(function(plr)
        task.spawn(function()
            local waited=0
            while waited<5 do
                task.wait(0.5); waited=waited+0.5
                if plr and plr.Parent and plr.Name~="" then
                    updateWL(); pcall(function() wlDD.Items=wlPN end); return
                end
            end
        end)
    end)
    Players.PlayerRemoving:Connect(function()
        task.wait(0.1); updateWL(); pcall(function() wlDD.Items=wlPN end)
    end)

    -- ============================================================
    -- LOGIC — INIT + RUNTIME LOOPS
    -- ============================================================
    task.defer(function()
        Window:Init()

        -- Inventory: force rebuild every second so display is always accurate
        task.spawn(function()
            while true do
                task.wait(1)
                S.markInvDirty()
                pcall(function()
                    waterLbl:Set("Water: "  ..S.countItem("Water"))
                    gelLbl:Set("Gelatin: "  ..S.countItem("Gelatin"))
                    sugLbl:Set("Sugar: "    ..S.countItem("Sugar Block Bag"))
                    bagLbl:Set("Empty Bag: "..S.countItem("Empty Bag"))
                    msBagLbl:Set("MS Bag: " ..S.countAllMS())
                end)
            end
        end)

        Library:Notification({
            Title       = "Phantom.wtf",
            Description = "Loaded! Have fun using our scripts!",
            Duration    = 5,
            Icon        = "135215559087473"
        })
    end)
end
