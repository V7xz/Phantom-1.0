            if not hasAllIngredients() then _setStatus("BAHAN HABIS!",Color3.fromRGB(255,60,90)); S.isRunning=false; break end
            local ok,err=pcall(doOneCook)
            if not ok then _setStatus("ERROR: "..tostring(err),Color3.fromRGB(255,60,90)); task.wait(2) end
            if S.isRunning then task.wait(0.3) end
        end
        S.isRunning=false; S.AutoMS_Running=false; _setStatus("OFF",Color3.fromRGB(255,60,90))
        phaseValue.Text="Water"; timerValue.Text="0s"; S.isBusy=false
    end
