        local bS=countItem(CFG.ITEM_MS_SMALL); local bM=countItem(CFG.ITEM_MS_MEDIUM); local bL=countItem(CFG.ITEM_MS_LARGE)
        setSt("Equip: "..msName.."...", Color3.fromRGB(100,180,255))
