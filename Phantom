    -- Force-rebuilds every second via S.markInvDirty() in GUI loop.
    -- ============================================================
    local _invCache = {}
    local _invDirty = true

    local function rebuildInvCache()
        local t  = {}
        local bp = LocalPlayer.Backpack
        if bp then
            for _,item in ipairs(bp:GetChildren()) do
                local n = item.Name
                if n and n ~= "" then t[n] = (t[n] or 0) + 1 end
            end
        end
        local ch = LocalPlayer.Character
        if ch then
            for _,item in ipairs(ch:GetChildren()) do
                if item:IsA("Tool") then
                    local n = item.Name; t[n] = (t[n] or 0) + 1
                end
            end
        end
        _invCache = t; _invDirty = false
    end

    local function onInvChanged() _invDirty = true end
    LocalPlayer.Backpack.ChildAdded:Connect(onInvChanged)
    LocalPlayer.Backpack.ChildRemoved:Connect(onInvChanged)
    LocalPlayer.CharacterAdded:Connect(function(char)
        _invDirty = true
        char.ChildAdded:Connect(onInvChanged)
        char.ChildRemoved:Connect(onInvChanged)
    end)
    if LocalPlayer.Character then
        LocalPlayer.Character.ChildAdded:Connect(onInvChanged)
        LocalPlayer.Character.ChildRemoved:Connect(onInvChanged)
    end

    local function countItem(name)
        if _invDirty then rebuildInvCache() end
        return _invCache[name] or 0
    end
    S.countItem    = countItem
    S.markInvDirty = function() _invDirty = true end

    local function totalMS()    return S.patStats.small+S.patStats.medium+S.patStats.large end
