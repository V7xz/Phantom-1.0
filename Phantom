            task.wait(0.3)
            local diff2=(bS-countItem(CFG.ITEM_MS_SMALL))+(bM-countItem(CFG.ITEM_MS_MEDIUM))+(bL-countItem(CFG.ITEM_MS_LARGE))
            if diff2>0 then S.totalSold=S.totalSold+diff2; sold=true; break end
