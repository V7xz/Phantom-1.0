    local cachedSeat = nil
    local function updSeat()
        local ch=LocalPlayer.Character; if not ch then cachedSeat=nil; return end
        for _,o in ipairs(ch:GetChildren()) do
            if o:IsA("Humanoid") then
                local s=o.SeatPart
                if s and (s:IsA("Seat") or s:IsA("VehicleSeat")) then cachedSeat=s; return end
            end
        end
        cachedSeat=nil
    end
    local function hookVC(c)
        local h=c:WaitForChild("Humanoid",10); if not h then return end
        h:GetPropertyChangedSignal("SeatPart"):Connect(updSeat); updSeat()
    end
