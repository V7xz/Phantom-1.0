        local spawnPos=targetPos+Vector3.new(0,0.5,0)
        local newCF=CFrame.new(spawnPos,spawnPos+Vector3.new(0,0,1))
        for _,p in ipairs(vehicle:GetDescendants()) do
            if p:IsA("BasePart") then pcall(function() p.AssemblyLinearVelocity=Vector3.zero; p.AssemblyAngularVelocity=Vector3.zero; p.Anchored=true end) end
        end
        task.wait(0.05)
        if vehicle.PrimaryPart then vehicle:SetPrimaryPartCFrame(newCF) else anchor.CFrame=newCF end
        task.wait(0.05)
        for _,p in ipairs(vehicle:GetDescendants()) do
            if p:IsA("BasePart") then pcall(function() p.Anchored=false; p.AssemblyLinearVelocity=Vector3.zero; p.AssemblyAngularVelocity=Vector3.zero end) end
        end
