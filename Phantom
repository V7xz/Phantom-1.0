S.whitelist = {}
-- ================================================================
-- ESP SYSTEM — FIXED & STABLE
-- Uses WorldToViewportPoint onScreen boolean (Majesty backend)
-- + Phantom corner-box visual style
-- ================================================================
do
    S.ESP_ENABLED   = false
    S.ESP_SKELETON  = false
    S.ESP_MAX_DIST  = 500
    S.ESP_BOX_COLOR = Color3.fromRGB(0, 255, 255)
    S._espPrev      = false

    local ESP_OBJ = {}
    local BONES = {
        {"Head","UpperTorso"}, {"UpperTorso","LowerTorso"},
        {"UpperTorso","LeftHand"}, {"UpperTorso","RightHand"},
        {"LowerTorso","LeftFoot"}, {"LowerTorso","RightFoot"},
    }

    local function hideESP(d)
        if not d then return end
        for i = 1, 4 do
            if d[i] then d[i][1].Visible=false; d[i][2].Visible=false end
        end
        if d.Name   then d.Name.Visible   = false end
        if d.Dist   then d.Dist.Visible   = false end
        if d.Item   then d.Item.Visible   = false end
        if d.HPBg   then d.HPBg.Visible   = false end
        if d.HPFill then d.HPFill.Visible = false end
        if d.Bones  then for i=1,#d.Bones do d.Bones[i].Visible=false end end
        d._vis = false
    end

    local function removeESP(plr)
        local d = ESP_OBJ[plr]; if not d then return end
        pcall(function()
            for i=1,4 do
                if d[i] then
                    if d[i][1] then d[i][1]:Remove() end
                    if d[i][2] then d[i][2]:Remove() end
                end
            end
            if d.Name   then d.Name:Remove()   end
            if d.Dist   then d.Dist:Remove()   end
            if d.Item   then d.Item:Remove()   end
            if d.HPBg   then d.HPBg:Remove()   end
            if d.HPFill then d.HPFill:Remove() end
            if d.Bones  then for i=1,#d.Bones do if d.Bones[i] then d.Bones[i]:Remove() end end end
        end)
        ESP_OBJ[plr] = nil
    end

    local function createESP(plr)
        if plr == LocalPlayer then return end
        if ESP_OBJ[plr] then return end
        local d = {}
        for _ = 1, 4 do
            local h = Drawing.new("Line"); h.Visible=false; h.Color=S.ESP_BOX_COLOR; h.Thickness=1.5
            local v = Drawing.new("Line"); v.Visible=false; v.Color=S.ESP_BOX_COLOR; v.Thickness=1.5
            d[#d+1] = {h, v}
        end
        local function mkTxt(sz, col)
            local t = Drawing.new("Text")
            t.Visible=false; t.Center=true; t.Outline=true
            t.OutlineColor=Color3.new(0,0,0); t.Color=col; t.Size=sz; t.Font=2
            return t
        end
        d.Name   = mkTxt(13, Color3.new(1,1,1))
        d.Dist   = mkTxt(11, Color3.fromRGB(200,200,200))
        d.Item   = mkTxt(11, Color3.fromRGB(255,220,50))
        d.HPBg   = Drawing.new("Square"); d.HPBg.Visible=false; d.HPBg.Color=Color3.fromRGB(20,20,20); d.HPBg.Filled=true; d.HPBg.Thickness=1
        d.HPFill = Drawing.new("Square"); d.HPFill.Visible=false; d.HPFill.Filled=true; d.HPFill.Thickness=1
        d.Bones  = {}
        for _ = 1, #BONES do
            local l = Drawing.new("Line"); l.Visible=false; l.Color=Color3.new(1,1,1); l.Thickness=1
            d.Bones[#d.Bones+1] = l
        end
        d._char=nil; d._hum=nil; d._hrp=nil; d._vis=false
        ESP_OBJ[plr] = d
    end

    -- FIX: Fast direct-child BasePart lookup (no FindFirstChild overhead)
    local function getPart(char, name)
        for _, child in ipairs(char:GetChildren()) do
            if child:IsA("BasePart") and child.Name == name then return child end
        end
        return nil
    end

    -- R6 body fallback
    local R6FB = {
        UpperTorso="Torso", LowerTorso="Torso",
        LeftHand="Left Arm", RightHand="Right Arm",
        LeftFoot="Left Leg", RightFoot="Right Leg",
    }
    local function getPartFB(char, name)
        local p = getPart(char, name)
        if p then return p end
        local fb = R6FB[name]
        return fb and getPart(char, fb)
    end

    -- FIX: Improved ESP update — stable, no flicker, handles all edge cases
    local function updateESP(plr, cam, myHRP)
        local d = ESP_OBJ[plr]; if not d then return end

        -- Validate character, re-cache if changed
        local char = plr.Character
        if not char or not char.Parent then
            if d._vis then hideESP(d) end; return
        end
        if d._char ~= char then
            d._char = char
            d._hum  = char:FindFirstChildOfClass("Humanoid")
            d._hrp  = getPart(char, "HumanoidRootPart")
        end
        local hum = d._hum; local hrp = d._hrp

        -- Re-validate cached refs (respawn safety)
        if not hum or not hum.Parent then d._hum = char:FindFirstChildOfClass("Humanoid"); hum = d._hum end
        if not hrp or not hrp.Parent then d._hrp = getPart(char, "HumanoidRootPart"); hrp = d._hrp end

        if not hum or hum.Health <= 0 or not hrp then
            if d._vis then hideESP(d) end; return
        end
        if S.whitelist[plr.Name] then
            if d._vis then hideESP(d) end; return
        end

        -- Distance check
        local dist3D = (hrp.Position - myHRP.Position).Magnitude
        if S.ESP_MAX_DIST > 0 and dist3D > S.ESP_MAX_DIST then
            if d._vis then hideESP(d) end; return
        end

        -- FIX: Use head for accurate top position
        local head = getPart(char, "Head")
        if not head then
            if d._vis then hideESP(d) end; return
        end

        local headPos = head.Position + Vector3.new(0, 0.5, 0)
        local rootPos = hrp.Position  - Vector3.new(0, 3,   0)

        -- FIX: WorldToViewportPoint returns (Vector3, onScreen bool)
        -- Using onScreen boolean instead of Z-check — more reliable near FOV edges
        local headSP, headOnScreen = cam:WorldToViewportPoint(headPos)
        local rootSP, rootOnScreen = cam:WorldToViewportPoint(rootPos)

        -- FIX: Show if EITHER point is on screen (handles player at edge / near camera)
        if not headOnScreen and not rootOnScreen then
            if d._vis then hideESP(d) end; return
        end

        -- FIX: Use min/max Y for stable box (no flip when camera tilts)
        local topY    = math.min(headSP.Y, rootSP.Y)
        local bottomY = math.max(headSP.Y, rootSP.Y)
        local h       = bottomY - topY

        -- FIX: 4px minimum (not 6) to keep distant players visible
        if h < 4 then
            if d._vis then hideESP(d) end; return
        end
        -- FIX: Remove maximum height cap — let box scale naturally with distance
        -- (old h > 500 cap was hiding close players)

        local centerX = (headSP.X + rootSP.X) * 0.5
        local w       = h * 0.60
        local bx      = centerX - w * 0.5
        local by      = topY

        -- FIX: Large viewport margin (300px) to prevent edge-culling nearby players
        local vs = cam.ViewportSize
        if bx+w < -300 or bx > vs.X+300 or by+h < -300 or by > vs.Y+300 then
            if d._vis then hideESP(d) end; return
        end

        -- Phantom corner-box rendering
        local col  = plr.Team and plr.Team.TeamColor.Color or S.ESP_BOX_COLOR
        local cLen = math.min(w, h) * 0.25

        d[1][1].From=Vector2.new(bx,   by);   d[1][1].To=Vector2.new(bx+cLen,by);    d[1][1].Color=col; d[1][1].Visible=true
        d[1][2].From=Vector2.new(bx,   by);   d[1][2].To=Vector2.new(bx,by+cLen);    d[1][2].Color=col; d[1][2].Visible=true
        d[2][1].From=Vector2.new(bx+w, by);   d[2][1].To=Vector2.new(bx+w-cLen,by);  d[2][1].Color=col; d[2][1].Visible=true
        d[2][2].From=Vector2.new(bx+w, by);   d[2][2].To=Vector2.new(bx+w,by+cLen);  d[2][2].Color=col; d[2][2].Visible=true
        d[3][1].From=Vector2.new(bx,   by+h); d[3][1].To=Vector2.new(bx+cLen,by+h);  d[3][1].Color=col; d[3][1].Visible=true
        d[3][2].From=Vector2.new(bx,   by+h); d[3][2].To=Vector2.new(bx,by+h-cLen);  d[3][2].Color=col; d[3][2].Visible=true
        d[4][1].From=Vector2.new(bx+w, by+h); d[4][1].To=Vector2.new(bx+w-cLen,by+h);d[4][1].Color=col; d[4][1].Visible=true
        d[4][2].From=Vector2.new(bx+w, by+h); d[4][2].To=Vector2.new(bx+w,by+h-cLen);d[4][2].Color=col; d[4][2].Visible=true

        -- Name + distance labels
        d.Name.Text=plr.Name; d.Name.Position=Vector2.new(centerX, by-16); d.Name.Visible=true
        d.Dist.Text=string.format("[%.0fm]", dist3D); d.Dist.Position=Vector2.new(centerX, by+h+4); d.Dist.Visible=true

        -- Tool/item label
        local toolName = nil
        for _, obj in ipairs(char:GetChildren()) do
            if obj:IsA("Tool") then toolName=obj.Name; break end
        end
        if toolName then
            d.Item.Text="["..toolName.."]"; d.Item.Position=Vector2.new(centerX, by+h+16); d.Item.Visible=true
        else
            if d.Item.Visible then d.Item.Visible=false end
        end

        -- HP bar
        local r   = math.clamp(hum.Health / math.max(hum.MaxHealth,1), 0, 1)
        local hh  = math.max(2, h * r)
        local hpX = bx - 5
        d.HPBg.Size=Vector2.new(2,h); d.HPBg.Position=Vector2.new(hpX,by); d.HPBg.Visible=true
        d.HPFill.Size=Vector2.new(2,hh); d.HPFill.Position=Vector2.new(hpX,by+h-hh)
        d.HPFill.Color = r>0.6 and Color3.fromRGB(0,255,80) or r>0.3 and Color3.fromRGB(255,200,0) or Color3.fromRGB(255,50,50)
        d.HPFill.Visible=true

        -- Skeleton
        if S.ESP_SKELETON then
            for i=1,#BONES do
                local b  = d.Bones[i]
                local p1 = getPartFB(char, BONES[i][1])
                local p2 = getPartFB(char, BONES[i][2])
                if p1 and p2 then
                    local s1, v1 = cam:WorldToViewportPoint(p1.Position)
                    local s2, v2 = cam:WorldToViewportPoint(p2.Position)
                    if v1 and v2 then
                        b.From=Vector2.new(s1.X,s1.Y); b.To=Vector2.new(s2.X,s2.Y); b.Visible=true
                    else
                        if b.Visible then b.Visible=false end
                    end
                else
                    if b.Visible then b.Visible=false end
                end
            end
        else
            for i=1,#d.Bones do if d.Bones[i].Visible then d.Bones[i].Visible=false end end
        end
        d._vis = true
    end

    -- Color update helper for colorpicker
    S.updateESPColor = function(col)
        for _, d in pairs(ESP_OBJ) do
            for i=1,4 do
                if d[i] then d[i][1].Color=col; d[i][2].Color=col end
            end
        end
    end

    -- FIX: RenderStepped at 30fps cap, hide-once on disable (no per-frame hide spam)
    local _ea = 0
    RunService.RenderStepped:Connect(function(dt)
        _ea = _ea + dt
        if not S.ESP_ENABLED then
            if S._espPrev then
                for _, d in pairs(ESP_OBJ) do hideESP(d) end
                S._espPrev = false
            end
            return
        end
        S._espPrev = true
        if _ea < 1/30 then return end
        _ea = 0
        local cam   = workspace.CurrentCamera
        local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end
        for plr in pairs(ESP_OBJ) do pcall(updateESP, plr, cam, myHRP) end
    end)

    -- FIX: task.defer for safe initial population; re-create on respawn
    for _, plr in pairs(Players:GetPlayers()) do task.defer(createESP, plr) end
    Players.PlayerAdded:Connect(function(plr)
        task.defer(createESP, plr)
        -- FIX: re-create ESP when character respawns
        plr.CharacterAdded:Connect(function()
            task.wait(0.5)
            removeESP(plr)
            task.defer(createESP, plr)
        end)
    end)
    Players.PlayerRemoving:Connect(removeESP)
end

-- ================================================================
-- VEHICLE FLY — E = UP, Q = DOWN (cached parts for performance)
-- ================================================================
do
    S.vFlyOn  = false
    S.vFlySpd = 60
    local conn     = nil
    local vUp      = false
    local vDn      = false

    UserInputService.InputBegan:Connect(function(inp, gpe)
        if not S.vFlyOn or gpe then return end
        if inp.KeyCode == Enum.KeyCode.E then vUp = true end
        if inp.KeyCode == Enum.KeyCode.Q then vDn = true end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.KeyCode == Enum.KeyCode.E then vUp = false end
        if inp.KeyCode == Enum.KeyCode.Q then vDn = false end
    end)

    local function vFlyStart()
        if conn then conn:Disconnect(); conn = nil end
        local vPartsCache = {}
        local lastModel   = nil
        conn = RunService.RenderStepped:Connect(function(dt)
            local ch   = LocalPlayer.Character; if not ch then return end
            local hm   = ch:FindFirstChildOfClass("Humanoid"); if not hm then return end
            local seat = hm.SeatPart; if not seat then return end
            local mdl  = seat:FindFirstAncestorOfClass("Model") or seat
            if mdl ~= lastModel then
                lastModel   = mdl
                vPartsCache = {}
                for _, p in pairs(mdl:GetDescendants()) do
                    if p:IsA("BasePart") then table.insert(vPartsCache, p) end
                end
            end
            local root = mdl.PrimaryPart or seat
            local cf   = Camera.CFrame
            local fwd  = Vector3.new(cf.LookVector.X,0,cf.LookVector.Z)
            if fwd.Magnitude>0.01 then fwd=fwd.Unit else fwd=Vector3.new(0,0,-1) end
            local rgt  = Vector3.new(cf.RightVector.X,0,cf.RightVector.Z)
            if rgt.Magnitude>0.01 then rgt=rgt.Unit else rgt=Vector3.new(1,0,0) end
            local mv = Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then mv=mv+fwd end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then mv=mv-fwd end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then mv=mv-rgt end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then mv=mv+rgt end
            if vUp then mv=mv+Vector3.new(0,1,0) end
            if vDn then mv=mv-Vector3.new(0,1,0) end
            for i=1,#vPartsCache do
                local p = vPartsCache[i]
                pcall(function() p.AssemblyLinearVelocity=Vector3.zero; p.AssemblyAngularVelocity=Vector3.zero end)
            end
            if mv.Magnitude > 0 then
                mv = mv.Unit
                local np = root.Position + mv * S.vFlySpd * dt
                local ld = Vector3.new(cf.LookVector.X,0,cf.LookVector.Z)
                if ld.Magnitude>0.01 then ld=ld.Unit else ld=fwd end
                pcall(function()
                    local cp  = mdl:GetPivot()
                    local tcf = CFrame.new(np, np+ld)
                    local off = cp:ToObjectSpace(root.CFrame)
                    mdl:PivotTo(tcf * off:Inverse())
                end)
            end
        end)
    end

    local function vFlyStop()
        if conn then conn:Disconnect(); conn=nil end
        vUp=false; vDn=false
    end

    S.vFlyStart = vFlyStart
    S.vFlyStop  = vFlyStop
end

-- ================================================================
-- AIMBOT — with Majesty-style dynamic keybind system
-- ================================================================
do
    S.aimOn       = false
    S.aimMode     = "Camera"
    S.aimFOV      = 250
    S.aimSmooth   = 5
    S.aimPart     = "Head"
    S.aimPred     = false
    S.aimPredStr  = 0.165
    S.aimPriority = "Crosshair"
    S.aimMaxDist  = 500
    S.aimFovCol   = Color3.fromRGB(0, 196, 255)

    -- Dynamic keybind state (Majesty system — supports KeyCode + mouse buttons)
    S.aimKBType   = "KeyCode"
    S.aimKBCode   = _G.PhantomConfig.DefaultAimKey
    S.aimKBMBtn   = nil
    S.aimKBLabel  = _G.PhantomConfig.DefaultAimKey and _G.PhantomConfig.DefaultAimKey.Name or "E"
    S.aimKBMode   = "Hold"
    S.aimToggle   = false
    S.aimCapturing= false

    local mb4Held = false
    local mb5Held = false

    UserInputService.InputBegan:Connect(function(input)
        local kn = tostring(input.KeyCode):gsub("Enum%.KeyCode%.","")
        local un = tostring(input.UserInputType):gsub("Enum%.UserInputType%.","")
        if kn=="MouseButton4" or un=="MouseButton4" then mb4Held=true end
        if kn=="MouseButton5" or un=="MouseButton5" then mb5Held=true end
    end)
    UserInputService.InputEnded:Connect(function(input)
        local kn = tostring(input.KeyCode):gsub("Enum%.KeyCode%.","")
        local un = tostring(input.UserInputType):gsub("Enum%.UserInputType%.","")
        if kn=="MouseButton4" or un=="MouseButton4" then mb4Held=false end
        if kn=="MouseButton5" or un=="MouseButton5" then mb5Held=false end
    end)

    -- Dynamic display string for current aim key
    local function getAimDisplay()
        if S.aimKBType=="MouseButton" then
            local un = tostring(S.aimKBMBtn or ""):gsub("Enum%.UserInputType%.","")
            if un=="MouseButton2" then return "RMB"
            elseif un=="MouseButton3" then return "MMB"
            end
        elseif S.aimKBType=="MB4" then return "MB4"
        elseif S.aimKBType=="MB5" then return "MB5"
        elseif S.aimKBCode then return S.aimKBCode.Name end
        return "None"
    end
    S.aimGetDisplay = getAimDisplay

    local velCache = {}
    local aimCircle = Drawing.new("Circle")
    aimCircle.Thickness=1.5; aimCircle.Filled=false; aimCircle.Transparency=0.75
    aimCircle.NumSides=64; aimCircle.Color=S.aimFovCol; aimCircle.Visible=false
    S.aimCircle = aimCircle

    local function getPredPos(part, player)
        local now=tick(); local cur=part.Position
        if not velCache[player] then velCache[player]={lastPos=cur,lastVel=Vector3.zero,lastTime=now}; return cur end
        local c=velCache[player]; local dt=now-c.lastTime
        if dt>0 and dt<0.15 then c.lastVel=c.lastVel:Lerp((cur-c.lastPos)/dt,0.4)
        elseif dt>=0.15 then c.lastVel=Vector3.zero end
        c.lastPos=cur; c.lastTime=now
        if not S.aimPred then return cur end
        return cur + c.lastVel * S.aimPredStr
    end

    local function getBest()
        local vs = Camera.ViewportSize
        local mp = UserInputService:GetMouseLocation()
        local cx = S.aimMode=="FreeAim" and mp.X or vs.X*0.5
        local cy = S.aimMode=="FreeAim" and mp.Y or vs.Y*0.5
        local bestS=math.huge; local bestP=nil; local bestPlr=nil
        local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        for _, plr in pairs(Players:GetPlayers()) do
            if plr==LocalPlayer or S.whitelist[plr.Name] then continue end
            local char=plr.Character; if not char or not char.Parent then continue end
            local hum=char:FindFirstChildOfClass("Humanoid")
            local part=char:FindFirstChild(S.aimPart) or char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
            if not part or not part.Parent or not hum or hum.Health<=0 then continue end
            if myHRP and S.aimMaxDist>0 and (part.Position-myHRP.Position).Magnitude>S.aimMaxDist then continue end
            local sp, onSc = Camera:WorldToViewportPoint(part.Position); if not onSc then continue end
            local dx=sp.X-cx; local dy=sp.Y-cy
            local dSqr=dx*dx+dy*dy
            if dSqr > S.aimFOV*S.aimFOV then continue end
            local score = S.aimPriority=="Distance" and myHRP and (part.Position-myHRP.Position).Magnitude or math.sqrt(dSqr)
            if score < bestS then bestS=score; bestP=part; bestPlr=plr end
        end
        return bestP, bestPlr
    end

    -- FIX: Dynamic isAimHeld — reads live S.aimKBType/S.aimKBCode/S.aimKBMBtn
    local function isAimHeld()
        if S.aimCapturing then return false end
        if S.aimKBMode=="Toggle" then return S.aimToggle end
        if S.aimKBType=="MouseButton" then
            if S.aimKBMBtn==Enum.UserInputType.MouseButton2 then return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) end
            if S.aimKBMBtn==Enum.UserInputType.MouseButton3 then return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton3) end
        elseif S.aimKBType=="MB4" then return mb4Held
        elseif S.aimKBType=="MB5" then return mb5Held
        elseif S.aimKBType=="KeyCode" and S.aimKBCode then return UserInputService:IsKeyDown(S.aimKBCode) end
        return false
    end

    -- Toggle mode handler
    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe or S.aimCapturing then return end
        if S.aimOn and S.aimKBMode=="Toggle" then
            local trig = false
            if S.aimKBType=="MouseButton" then
                if S.aimKBMBtn==Enum.UserInputType.MouseButton2 and input.UserInputType==Enum.UserInputType.MouseButton2 then trig=true end
                if S.aimKBMBtn==Enum.UserInputType.MouseButton3 and input.UserInputType==Enum.UserInputType.MouseButton3 then trig=true end
            elseif S.aimKBType=="MB4" and mb4Held then trig=true
            elseif S.aimKBType=="MB5" and mb5Held then trig=true
            elseif S.aimKBType=="KeyCode" and S.aimKBCode and input.KeyCode==S.aimKBCode then trig=true
            end
            if trig then S.aimToggle=not S.aimToggle end
        end
    end)

    local mmMethod=nil; pcall(function() if mousemoverel then mmMethod="rel" end end)
    local function moveRel(dx, dy)
        if mmMethod=="rel" then mousemoverel(dx,dy)
        else local mmp=UserInputService:GetMouseLocation(); pcall(function() VIM:SendMouseMoveEvent(mmp.X+dx,mmp.Y+dy,false) end) end
    end

    local _fpX,_fpY,_fRC=0,0,250
    RunService:BindToRenderStep("PhantomAimbot", 201, function(dt)
        local vs = Camera.ViewportSize
        local mp = UserInputService:GetMouseLocation()
        local tcX = S.aimMode=="FreeAim" and mp.X or vs.X*0.5
        local tcY = S.aimMode=="FreeAim" and mp.Y or vs.Y*0.5
        if _fpX==0 then _fpX=tcX end; if _fpY==0 then _fpY=tcY end
        local fL = math.clamp(dt*40,0,1)
        _fpX=_fpX+(tcX-_fpX)*fL; _fpY=_fpY+(tcY-_fpY)*fL; _fRC=_fRC+(S.aimFOV-_fRC)*fL
        if aimCircle then
            aimCircle.Position=Vector2.new(_fpX,_fpY)
            aimCircle.Radius=_fRC
            aimCircle.Color=S.aimFovCol
            aimCircle.Visible=S.aimOn
        end
        if not S.aimOn or not isAimHeld() then return end
        local target,tPlr=getBest(); if not target then return end
        local pos=getPredPos(target,tPlr)
        if S.aimMode=="Camera" then
            local cf=Camera.CFrame; local goal=CFrame.new(cf.Position,pos)
            if S.aimSmooth<=0 then Camera.CFrame=goal
            else
                local f=math.clamp(1-S.aimSmooth/20,0.05,0.95)
                local t=math.clamp(1-(1-f)^(dt/0.016),0.02,1)
                Camera.CFrame=cf:Lerp(goal,t)
            end
        else
            local sp,onSc=Camera:WorldToViewportPoint(pos); if not onSc then return end
            local mmp=UserInputService:GetMouseLocation(); local dx=sp.X-mmp.X; local dy=sp.Y-mmp.Y
            if S.aimSmooth<=0 then moveRel(dx,dy)
            else
                local f=math.clamp(1-S.aimSmooth/20,0.05,0.95)
                local t=math.clamp(1-(1-f)^(dt/0.016),0.02,1)
                moveRel(dx*t,dy*t)
            end
        end
    end)
end

